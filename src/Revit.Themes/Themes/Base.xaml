<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="Revit.BackgroundBrush" Color="{DynamicResource Revit.BackgroundColor}" />
  <SolidColorBrush x:Key="Revit.ControlBackgroundBrush" Color="{DynamicResource Revit.ControlBackgroundColor}" />
  <SolidColorBrush x:Key="Revit.BorderBrush" Color="{DynamicResource Revit.BorderColor}" />
  <SolidColorBrush x:Key="Revit.ForegroundBrush" Color="{DynamicResource Revit.ForegroundColor}" />
  <SolidColorBrush x:Key="Revit.HighlightBrush" Color="{DynamicResource Revit.HighlightColor}" />

  <Style TargetType="Window">
    <Setter Property="Background" Value="{DynamicResource Revit.BackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource Revit.ForegroundBrush}" />
  </Style>

  <Style TargetType="Control">
    <Setter Property="Background" Value="{DynamicResource Revit.ControlBackgroundBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource Revit.ForegroundBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Revit.BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style TargetType="Button" BasedOn="{StaticResource {x:Type Control}}">
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="Margin" Value="2" />
  </Style>

  <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type Control}}">
    <Setter Property="Padding" Value="4" />
    <Setter Property="Margin" Value="2" />
  </Style>

  <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type Control}}">
    <Setter Property="Padding" Value="4" />
    <Setter Property="Margin" Value="2" />
  </Style>

  <Style TargetType="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource Revit.ForegroundBrush}" />
    <Setter Property="Margin" Value="2" />
  </Style>

  <Style TargetType="ListBox" BasedOn="{StaticResource {x:Type Control}}">
    <Setter Property="Padding" Value="2" />
    <Setter Property="Margin" Value="2" />
  </Style>
</ResourceDictionary>
